{
  "manifest_version": 3,
  "name": "動画クオリティ・チェッカー",
  "version": "1.0.0",
  "description": "YouTube動画の最初の3分を分析し、収益化審査の合格水準かを判定する補助機能",
  "permissions": [
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://*.youtube.com/*",
    "https://shinji-design.github.io/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://shinji-design.github.io/yt-quality-checker/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": ["content-page.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "動画クオリティ・チェッカー"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
